{
  "entities": {
    "users": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the user." },
        "name": { "type": "string", "description": "The name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email address of the user." },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "The role of the user." },
        "created_at": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["id", "name", "email", "role"]
    },
    "products": {
      "title": "Product",
      "description": "A furniture product.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the product." },
        "title": { "type": "string", "description": "The title of the product." },
        "description": { "type": "string", "description": "The description of the product." },
        "price": { "type": "number", "description": "The price of the product." },
        "stock": { "type": "integer", "description": "The stock quantity of the product." },
        "category": { "type": "string", "description": "The category of the product." },
        "image_url": { "type": "string", "description": "The main image of the product." },
        "reel_link": { "type": "string", "description": "The Instagram reel link for the product." },
        "is_active": { "type": "boolean", "description": "Whether the product is visible to customers." },
        "created_at": { "type": "string", "format": "date-time", "description": "When the product was created." }
      },
      "required": ["id", "title", "description", "price", "stock", "category", "image_url"]
    },
    "orders": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the order." },
        "user_id": { "type": "string", "description": "The ID of the user who placed the order." },
        "total_amount": { "type": "number", "description": "The total amount of the order." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered"], "description": "The status of the order." },
        "address": { "type": "string", "description": "The shipping address." },
        "payment_method": { "type": "string", "description": "The payment method used." },
        "customer_name": { "type": "string", "description": "The name of the customer." },
        "customer_phone": { "type": "string", "description": "The phone number of the customer." },
        "created_at": { "type": "string", "format": "date-time", "description": "When the order was created." }
      },
      "required": ["id", "user_id", "total_amount", "status", "address", "created_at"]
    },
    "order_items": {
      "title": "Order Item",
      "description": "An item within an order.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the order item." },
        "order_id": { "type": "string", "description": "The ID of the parent order." },
        "product_id": { "type": "string", "description": "The ID of the product." },
        "quantity": { "type": "integer", "description": "The quantity ordered." },
        "price": { "type": "number", "description": "The price at the time of order." },
        "title": { "type": "string", "description": "The title of the product." },
        "image_url": { "type": "string", "description": "The image of the product." }
      },
      "required": ["id", "order_id", "product_id", "quantity", "price", "title"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "users", "description": "User profile data." },
    "/products/{productId}": { "schema": "products", "description": "Product data." },
    "/orders/{orderId}": { "schema": "orders", "description": "Order data." },
    "/order_items/{itemId}": { "schema": "order_items", "description": "Order item data." }
  }
}
